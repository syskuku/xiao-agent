{
  "xiaomi": {
    "username": "your_xiaomi_username",
    "password": "your_xiaomi_password"
  },
  "openai_api": {
    "base_url": "https://api.openai.com/v1",
    "api_key": "your_openai_api_key",
    "model": "gpt-3.5-turbo"
  },
  "websocket": {
    "host": "localhost",
    "port": 8765
  },
  "browser_control": {
    "enable_ai": true,
    "default_timeout": 10,
    "enable_keyword_fallback": true
  },
  "conversation": {
    "pull_interval": 2,
    "enable_pull_ask": true
  }
}
