{
  "xiaomi": {
    "username": "your_xiaomi_username",
    "password": "your_xiaomi_password"
  },
  "openai_api": {
    "base_url": "https://api.openai.com/v1",
    "api_key": "your_openai_api_key",
    "model": "gpt-3.5-turbo"
  },
  "websocket": {
    "host": "localhost",
    "port": 8765
  },
  "browser_control": {
    "enable_ai": true,
    "default_timeout": 10,
    "enable_keyword_fallback": true
  },
  "conversation": {
    "pull_interval": 2,
    "enable_pull_ask": true,
    "tts_enabled": true,
    "tts_confirm": "好的，正在处理",
    "tts_success": "已完成",
    "tts_error": "抱歉，执行失败"
  },
  "mcp_servers": [
    {
      "name": "windows",
      "type": "stdio",
      "command": "python",
      "args": ["mcp_windows_server.py"]
    }
  ]
}
