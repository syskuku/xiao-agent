{
  "manifest_version": 3,
  "name": "xiao-agent",
  "version": "1.0.0",
  "description": "XiaoAi Speaker Browser Controller",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "xiao-agent"
  }
}