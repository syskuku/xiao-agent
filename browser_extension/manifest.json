{
  "manifest_version": 3,
  "name": "小爱音箱浏览器控制器",
  "version": "1.0.0",
  "description": "通过小爱音箱语音指令控制浏览器的Chrome扩展",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "debugger",
    "webNavigation",
    "notifications"
  ],
  "host_permissions": [
    "http://localhost:8765/",
    "ws://localhost:8765/"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "小爱音箱浏览器控制器"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["content.js"],
      "matches": ["<all_urls>"]
    }
  ]
}